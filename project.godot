; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Endless-Train2.0"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.7", "C#", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/GameManager.cs"

[display]

window/size/viewport_width=540
window/size/viewport_height=960
window/size/window_width_override=810
window/size/window_height_override=1440
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="Endless-Train2.0"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
